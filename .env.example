SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=password
EMAIL_FROM=reklamace@proteinaco.cz
EMAIL_FROM_NAME=Proteinaco

# Admin Portal
ADMIN_PORTAL_URL=http://localhost:8000

# Uploads
UPLOAD_DIR=./uploads/complaints

# CORS
CORS_ORIGINS=http://localhost:8040,https://www.proteinaco.cz
