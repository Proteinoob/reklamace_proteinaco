# Database
DATABASE_URL=postgresql://user:password@host:25060/reklamace_db?sslmode=require

# Security
SECRET_KEY=change-this-in-production

# Shoptet API
SHOPTET_API_BASE=https://api.myshoptet.com
SHOPTET_TOKEN_CZ=your-shoptet-token

# Zásilkovna
ZASILKOVNA_API_KEY=your-api-key
